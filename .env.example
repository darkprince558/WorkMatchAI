# App runtime
NEXT_PUBLIC_APP_NAME="WorkMatch AI"
APP_URL="http://localhost:3000"
DISABLE_HMR="false"

# Database and persistence
DATABASE_URL=""
SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_STORAGE_BUCKET="workmatch-uploads"

# Auth and sessions
AUTH_SECRET=""
WORKMATCH_AUTH_MODE="supabase"
WORKMATCH_ALLOW_SELF_SIGN_UP="false"
WORKMATCH_TRUST_PROXY_HEADERS="false"
WORKMATCH_DEFAULT_ORGANIZATION_ID=""
WORKMATCH_DEMO_ORGANIZATION_ID="demo-organization"
WORKMATCH_DEMO_USER_ID="demo-manager"
WORKMATCH_DEMO_ROLE="manager"

# AI routes
AI_PROVIDER="gemini"
OPENAI_API_KEY=""
OPENAI_MODEL=""
OPENAI_BASE_URL="https://api.openai.com/v1"
OPENAI_INPUT_COST_PER_1M_TOKENS="0"
OPENAI_OUTPUT_COST_PER_1M_TOKENS="0"
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"
GEMINI_INPUT_COST_PER_1M_TOKENS="0"
GEMINI_OUTPUT_COST_PER_1M_TOKENS="0"

# Microsoft 365 intake is the future cloud-document path.
# Local Microsoft Office files are already supported through XLSX/DOCX upload.
MICROSOFT_CLIENT_ID=""
MICROSOFT_CLIENT_SECRET=""
MICROSOFT_TENANT_ID=""
MICROSOFT_REDIRECT_URI="http://localhost:3000/api/auth/microsoft/callback"
MICROSOFT_GRAPH_SCOPES="Files.Read User.Read offline_access"

